{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "deep-link:default",
    "store:default",
    "keyring:default",
    "core:tray:default",
    "notification:default",
    "process:default",
    "updater:default"
  ]
}
