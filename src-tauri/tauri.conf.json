{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gitlabify",
  "version": "1.2.0",
  "identifier": "com.godart-corentin.gitlabify",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "gitlabify",
        "width": 480,
        "height": 300,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/godart-corentin/gitlabify/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA5NzdBRjNDQzZBNDI2NjgKUldSb0pxVEdQSzkzQ1M3Vkl1Qk04c3RSNlJERXJ6cFQ3VE5YT0xWOTZtWGtKZzhEekFHb3VYT1YK"
    },
    "deep-link": {
      "mobile": [],
      "desktop": [
        {
          "schemes": ["gitlabify"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
